#include <iostream>
using namespace std;

int sayi;


int main() {
    //İşlem döngüsü
    while (true) {                            //Kodu while döngüsüne alıyorum kodu sürekli çaliştirmak zor oluyor gerçek projedede böyle olmalı diye düşünüyorum
        //Kullanıcı etkileşimi
        cout << "Çarpım tablosu için bir sayi giriniz: ";
        cin >> sayi;
        //Çarpım işlem yeri
        for (int i = 1; i <= 10; i++) {                         //(Başlangıç, Koşul, Artış) bu kuralı for döngüsüne uyguluyorum
            cout << sayi << " x " << i << " = " << sayi * i << endl;   
        }

        return 0;                   //For döngüsünü sıfırlıyorum
    }
}
